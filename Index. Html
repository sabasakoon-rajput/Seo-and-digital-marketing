.services{
padding:70px 80px;
text-align:center;
}

.services h2{
font-size:32px;
margin-bottom:40px;
}

.service-container{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:25px;
}

.service-card{
background:white;
padding:30px;
border-radius:10px;
box-shadow:0 4px 15px rgba(0,0,0,0.1);
transition:0.3s;
}

.service-card:hover{
transform:translateY(-5px);
}

.service-card h3{
margin-bottom:15px;
color:#0077b6;
}

/* About */

.about{
display:flex;
gap:40px;
padding:70px 80px;
align-items:center;
}

.about img{
width:400px;
border-radius:10px;
}

.about-text h2{
margin-bottom:20px;
font-size:30px;
}

/* CTA */

.cta{
background:#0077b6;
color:white;
text-align:center;
padding:60px 20px;
}

.cta h2{
margin-bottom:20px;
font-size:32px;
}

/* Footer */

footer{
background:#0d1b2a;
color:white;
text-align:center;
padding:20px;
margin-top:40px;
