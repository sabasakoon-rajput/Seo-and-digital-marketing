}

.hero-text{
max-width:500px;
}

.hero-text h1{
font-size:48px;
margin-bottom:20px;
}

.hero-text p{
font-size:18px;
margin-bottom:25px;
}

.btn{
background:white;
color:#0077b6;
padding:12px 28px;
border:none;
border-radius:25px;
text-decoration:none;
font-weight:bold;
}

.btn:hover{
