transition:0.3s;
}

nav a:hover{
color:#00b4d8;
}

/* Hero Section */

.hero{
display:flex;
align-items:center;
justify-content:space-between;
padding:80px;
background:linear-gradient(120deg,#0077b6,#00b4d8);
